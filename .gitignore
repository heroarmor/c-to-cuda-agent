# Compiled C / CUDA artifacts
*.o
*.obj
*.out
*.exe
*.so
*.a
a.out

# CUDA / build outputs
*.ptx
*.cubin
*.fatbin
build/
bin/

# macOS
.DS_Store

# Claude Code local settings (personal, not shared)
.claude/settings.local.json

# Python
__pycache__/
*.pyc
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.ipynb_checkpoints/

# Editor/IDE
.vscode/
.idea/
*.swp

# Personal notes (not tracked)
explain.md

# dataset_zyj build output: compiled benchmark binaries and the synthetic
# llama2 checkpoint/tokenizer data, both regenerated by `make all`
dataset_zyj/bin/
dataset_zyj/data/

# opencode: track config + custom commands, ignore local deps/state
.opencode/node_modules/
.opencode/package.json
.opencode/package-lock.json
.opencode/bun.lock
.opencode/.gitignore

# image outputs written to CWD by mandelbrot/raytrace/pathtrace runs
# (the reference images under benchmark/ stay tracked)
/*.pgm
/*.ppm

# generated evaluation reports / raw TSVs (framework + .gitkeep stay tracked)
evaluation/results/*
!evaluation/results/.gitkeep

# agent run outputs (reproducible by re-running the scripts)
generated/
agent_pipeline/runs/
test_results/
dataset_eval/reports/
